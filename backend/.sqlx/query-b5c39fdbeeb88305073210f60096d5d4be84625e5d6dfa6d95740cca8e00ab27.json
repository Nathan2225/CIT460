  "query": "\n                                SELECT s.server_id, s.name_server, s.server_code, s.owner_id\n                                FROM servers s\n                                JOIN server_members sm ON s.server_id = sm.server_mem\n                                WHERE sm.user_mem = $1\n                                ",
